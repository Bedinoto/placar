// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: matches
// Document ID: matchCode (e.g., 4-6 digit string)
// Fields:
//   - points: list (required) - [Score, Score]
//   - games: list (required) - [number, number]
//   - sets: list (required) - [number, number]
//   - setHistory: list (optional) - [[number, number], ...]
//   - server: number (required) - 0 or 1
//   - isGameOver: bool (required)
//   - winner: number (optional) - 0 or 1
//   - gameMode: string (required) - 'padel' or 'beach'
//   - teamNames: list (required) - [string, string]
//   - bestOf: number (required) - 1, 3, 5
//   - goldenPoint: bool (required)
//   - updatedAt: timestamp (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidMatch(data) {
      return data.points is list && data.points.size() == 2 &&
             data.games is list && data.games.size() == 2 &&
             data.sets is list && data.sets.size() == 2 &&
             (data.setHistory == null || data.setHistory is list) &&
             data.gameMode in ['padel', 'beach'] &&
             data.teamNames is list && data.teamNames.size() == 2 &&
             data.teamNames[0] is string && data.teamNames[0].size() <= 50 &&
             data.teamNames[1] is string && data.teamNames[1].size() <= 50 &&
             data.bestOf in [1, 3, 5] &&
             data.isGameOver is bool &&
             data.goldenPoint is bool &&
             data.server in [0, 1] &&
             (data.winner == null || data.winner in [0, 1]) &&
             (data.createdByEmail == null || data.createdByEmail is string) &&
             (data.createdById == null || data.createdById is string);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "uillian.bedinoto@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /matches/{matchId} {
      // Allow any authenticated user to read/write matches if they have the ID
      // In a real app, we might want to restrict this to creators, but for a shared scoreboard,
      // anyone with the code should be able to participate.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMatch(request.resource.data);
      allow update: if isAuthenticated() && isValidMatch(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
